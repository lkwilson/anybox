# Set usr bin
usr_bin="$HOME/.local/bin"
if [ -d "$usr_bin" ]; then
    PATH="$usr_bin:$PATH"
fi

# bash completion
if ! shopt -oq posix; then
    if [ -f /usr/share/bash-completion/bash_completion ]; then
        bash_completion_base=/usr/share/bash-completion
    elif [ -f /etc/bash_completion ]; then
        bash_completion_base=/etc
    elif [ -f /opt/homebrew/etc/bash_completion ]; then
        bash_completion_base=/opt/homebrew/etc
    elif [ -d /run/current-system/sw/share/bash-completion ]; then
        bash_completion_base=/run/current-system/sw/share/bash-completion
    fi
    if [ -f $bash_completion_base/bash_completion ]; then
        . $bash_completion_base/bash_completion
    fi
fi

# git
setup_git() {
    function_exists() {
      declare -f -F $1 > /dev/null
      return $?
    }

    if ! function_exists __git_aliased_command; then
        if [ -r "$bash_completion_base/completions/git" ]; then
            . "$bash_completion_base/completions/git"
        else
            return
        fi
    fi

    for al in $(git config --get-regexp '^alias\.' | cut -f 1 -d ' ' | cut -f 2 -d '.'); do
        alias g$al="git $al"
        complete_func=_git_$(__git_aliased_command $al)
        function_exists $complete_func && __git_complete g$al $complete_func
    done
    unset al

    # Set git branch PS1
    _ps1_git_prefix() {
        if git rev-parse &>/dev/null; then
            _ps1_git=$(git branch-name 2>/dev/null)
        else
            _ps1_git=''
        fi
    }
    PROMPT_COMMAND="_ps1_git_prefix;$PROMPT_COMMAND"
}

# git
if type git &>/dev/null; then
    setup_git
fi

# k8s
if type kubectl &>/dev/null; then
    alias k=kubectl
    source <(kubectl completion bash)
    complete -F __start_kubectl k
    export KUBECONFIG="$HOME/.kube/config"
fi

if type flux &>/dev/null; then
    . <(flux completion bash)
fi

# nix
if type nix &>/dev/null; then
    ne() {
        if [ "$IN_NIX_SHELL" != "" ]; then
            exit 0
        fi
    }
    alias nd='nix develop'
    alias nds='nix develop .?submodules=1'
    # Set nix branch PS1
    _ps1_nix_prefix() {
        if [ "$IN_NIX_SHELL" != '' ]; then
            _ps1_scope='*'
        else
            _ps1_scope=''
        fi
    }
    PROMPT_COMMAND="_ps1_nix_prefix;$PROMPT_COMMAND"
fi

# vs code
if ! type code &>/dev/null; then
  mac_vsc_bin="/Applications/Visual Studio Code.app/Contents/Resources/app/bin"
  if [ -d "$mac_vsc_bin" ]; then
    export PATH="$mac_vsc_bin:$PATH"
  fi
fi

if type code &>/dev/null; then
  alias ch='code .'
fi

# rust
if [ -r "$HOME/.cargo/env" ]; then
  . "$HOME/.cargo/env"
fi

# clip: pipe stdin to the system clipboard, cross-platform and SSH-aware.
#
#   some-command | clip
#
# Local sessions use the native clipboard tool (macOS pbcopy, WSL clip.exe,
# Wayland/X11). Over SSH there is no local tool that can reach the machine
# you're sitting at, so it falls back to an OSC 52 escape sequence: this asks
# the terminal emulator to set the clipboard, so piping to clip from a remote
# host copies to your local machine. Needs a terminal that honors OSC 52
# (kitty, iTerm2, recent tmux/screen, etc.).
_clip_osc52() {
  local b64 seq
  b64=$(base64 | tr -d '\n')
  seq="\033]52;c;${b64}\a"
  # tmux/screen need the sequence wrapped in their passthrough envelope.
  if [ -n "$TMUX" ]; then
    seq="\033Ptmux;\033${seq}\033\\"
  elif [ "${TERM%%-*}" = "screen" ]; then
    seq="\033P${seq}\033\\"
  fi
  # Write to the controlling terminal so a redirected stdout still reaches it.
  printf "%b" "$seq" > /dev/tty
}
clip() {
  if [ -n "$SSH_CONNECTION" ] || [ -n "$SSH_TTY" ]; then
    _clip_osc52
  elif type pbcopy &>/dev/null; then
    pbcopy                       # macOS
  elif type clip.exe &>/dev/null; then
    clip.exe                     # WSL
  elif type wl-copy &>/dev/null; then
    wl-copy                      # Wayland
  elif type xclip &>/dev/null; then
    xclip -selection clipboard   # X11
  elif type xsel &>/dev/null; then
    xsel --clipboard --input     # X11
  else
    _clip_osc52                  # last resort: terminal escape
  fi
}